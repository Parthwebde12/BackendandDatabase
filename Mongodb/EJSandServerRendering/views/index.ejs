<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <link rel="stylesheet" href="../public/stylesheets/style.css">
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>

    <title>Document</title>
</head>

<body class="bg-zinc-900">
<div class="w-full min-h-screen bg-zinc-800 text-white p-10">
    <div class="nav mb-10">
        <a href="/read" class="text-blue-500">read users</a>
        
    </div>
    <h1 class="text-3xl tracking-tighter mb-3">Create User</h1>
        <form action="/create" method="post">
            <input type="text"name="name"placeholder="Name"class="px-5 py-2 bg-transparent border border-zinc-800 rounded-lg outline">
            <input type="email"name="email"placeholder="email"class="px-5 py-2 bg-transparent border border-zinc-800 rounded-lg outline">
            <input type="text"name="image"placeholder="image url"class="px-5 py-2 bg-transparent border border-zinc-800 rounded-lg outline">
            <input type="submit" value="user" class="px-5 py-5 rounded-lg bg-blue-500 ml-3">
        </form>
    </div>

</body>
</html>