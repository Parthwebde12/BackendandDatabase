<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <link rel="stylesheet" href="../public/stylesheets/style.css">
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>

    <title>Document</title>
</head>

<body class="bg-zinc-900">
<div class="w-full min-h-screen bg-zinc-800 text-white p-10">
    <a href="/" class="text-blue-500">BACK TO HOME</a>
    <h1 class="text-3xl tracking-tighter mb-3 mt-3">All Users</h1>
      <div class="users flex gap-3 flex-wrap">
        <% users.forEach(function(user){ %>

           
        <div class="user max-w-72 p-10 bg-zinc-700 rounded-lg">
            <img src="<%= user.image %>" alt="User Image" class="w-full h-72 object-cover rounded-lg">
            <h2 class="text-xl mt-3"><%= user.name %> </h2>
            <h3 class="text-zinc-400"><%= user.email %></h3>
            <div class="flex gap-3 mt-5">
                <a href="" class="text-blue-500">Edit</a>
                <a href="" class="text-red-500">Delete</a>
            </div>
        </div>
         <% })%>
         
        
      </div>
    </div>

</body>
</html>